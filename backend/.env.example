FLASK_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-different-long-random-secret
DATABASE_URL=postgresql://postgres:password@host:5432/postgres
CORS_ORIGINS=https://your-frontend.example.com
AUTO_CREATE_DB=false
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=server-side-service-role-key
SUPABASE_STORAGE_BUCKET=product-images
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=notifications@example.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM=notifications@example.com
SCALE_INGEST_API_KEY=replace-with-a-long-random-device-secret
# Bind the device secret to one business account in production.
SCALE_INGEST_USER_ID=1
SCALE_DEVICE_ID=pi-vda-01
SCALE_MAX_AGE_SECONDS=10
SCALE_MAX_INGEST_AGE_SECONDS=60
SCALE_MAX_WEIGHT_KG=300
