[Unit]
Description=UpScale Raspberry Pi weight transfer bridge
After=network-online.target upscale-hx711.service
Wants=network-online.target
Requires=upscale-hx711.service

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/upscale/backend
EnvironmentFile=/etc/upscale/scale-bridge.env
ExecStart=/opt/upscale/venv/bin/python /opt/upscale/backend/scripts/scale_push_bridge.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
